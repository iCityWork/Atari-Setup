{
  "version": "2.0.0",
  "tasks": [

    {
      "label": "Make: Run → Atari 400/800 Debug + Launch",
      "type": "shell",
      "command": "make run",
      "options": { "cwd": "${workspaceFolder}" },
      "group": { "kind": "build", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared", "clear": true },
      "problemMatcher": {
        "owner": "cc65",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.+)\\((\\d+)\\):\\s+(Error|Warning|Note):\\s+(.+)$",
          "file": 1, "line": 2, "severity": 3, "message": 4
        }
      },
      "detail": "Atari 400/800 debug build + auto-launch.  (Ctrl+Shift+B)"
    },

